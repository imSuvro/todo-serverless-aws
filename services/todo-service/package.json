{
  "name": "todo-service",
  "version": "1.0.0",
  "description": "Todo CRUD service — AWS Lambda + API Gateway + DynamoDB",
  "main": "handler.js",
  "scripts": {
    "build": "tsc",
    "test": "jest --passWithNoTests",
    "deploy": "serverless deploy --stage dev --region ap-south-1"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0",
    "@aws-sdk/client-sqs": "^3.0.0",
    "@aws-sdk/client-sns": "^3.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.0",
    "@types/uuid": "^9.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0",
    "ts-jest": "^29.0.0",
    "jest": "^29.0.0",
    "serverless": "^3.0.0",
    "serverless-esbuild": "^1.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"]
  }
}
